<?xml version="1.0" ?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
	<system>
		<section id="aiconnector" sortOrder="0" showInWebsite="1" showInStore="1" showInDefault="1" translate="label">
			<label>Ai Connector</label>
			<tab>service</tab>
			<resource>Gtstudio_AiConnector::config_gtstudio_aiconnector</resource>
			<group id="general" sortOrder="10" showInWebsite="1" showInStore="1" showInDefault="1" translate="label">
				<label>General</label>
				<field id="enabled" type="select" sortOrder="10" showInWebsite="1" showInStore="1" showInDefault="1" translate="label">
					<label>Enabled</label>
					<comment/>
					<source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
				</field>
				<field id="privider" type="text" sortOrder="10" showInWebsite="1" showInStore="1" showInDefault="1" translate="label">
					<label>Provider</label>
					<comment>Ai API provider</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
				</field>
				<field id="domain" type="text" sortOrder="10" showInWebsite="1" showInStore="1" showInDefault="1" translate="label">
					<label>AI API Domain</label>
					<comment>Enter the base domain for the AI API (e.g. https://api.openai.com)</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
				</field>
				<field id="key" type="obscure" sortOrder="10" showInWebsite="1" showInStore="1" showInDefault="1" translate="label">
					<label>API Key</label>
					<comment>Enter your provider API key</comment>
					<backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
					<config_path>aiconnector/general/key</config_path>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
				</field>
				<field id="model" type="text" sortOrder="10" showInWebsite="1" showInStore="1" showInDefault="1" translate="label">
					<label>AI Model</label>
					<comment>Ai Model, ex : GPT 3.5 Turbo 0125, GPT 4.1 Nano, etc</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
				</field>
				<field id="max_tokens" type="text" sortOrder="10" showInWebsite="1" showInStore="1" showInDefault="1" translate="label">
					<label>Max Tokens</label>
					<comment>Maximum number of tokens to generate (1-4000)</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
				</field>
				<field id="temperature" type="text" sortOrder="10" showInWebsite="1" showInStore="1" showInDefault="1" translate="label">
					<label>Temperature</label>
					<comment>Controls randomness (0.0-1.0). Lower is more focused, higher is more creative.</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
				</field>
				<field id="rules" type="textarea" sortOrder="10" showInWebsite="1" showInStore="1" showInDefault="1" translate="label">
					<label>AI Rules</label>
					<comment>Define rules and guidelines for the AI model</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
				</field>
			</group>
			<group id="debugging" sortOrder="10" showInWebsite="1" showInStore="1" showInDefault="1" translate="label">
				<label>Monitoring &amp; Debugging</label>
				<field id="inspector_ingestion_key" type="obscure" sortOrder="10" showInWebsite="1" showInStore="1" showInDefault="1" translate="label">
					<label>Inspector Ingestion Key</label>
					<comment>Debug and monitor inputs and outputs with inspector [https://inspector.dev/]</comment>
					<backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
					<config_path>aiconnector/debugging/inspector_ingestion_key</config_path>
				</field>
			</group>
		</section>
	</system>
</config>
